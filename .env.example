# =====================================================
# Frontend – Variables de entorno (Producción / Dokploy)
# =====================================================
# Copiar a .env.local y rellenar con valores reales.
# Variables NEXT_PUBLIC_* se inyectan EN TIEMPO DE BUILD.
# =====================================================

# ── General ──────────────────────────────────────────
NODE_ENV=production

# ── URLs públicas (inyectadas al build) ──────────────
# URL del frontend (canonical)
NEXT_PUBLIC_APP_URL=https://app.midominio.com

# URL pública del backend Fastify (para llamadas desde el navegador)
NEXT_PUBLIC_EXTERNAL_API_URL=https://api.midominio.com

# WebSocket público del backend
NEXT_PUBLIC_WS_URL=wss://api.midominio.com/ws/lecturas

# ── URLs privadas (solo server-side, NO NEXT_PUBLIC) ─
# URL interna del backend (dentro de la red Docker)
# En producción: http://backend:3100
# En desarrollo local: http://localhost:3100
EXTERNAL_API_URL=http://backend:3100

# ── Observabilidad (Opcional) ────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
