# =====================================================
# Frontend – Variables de entorno (Producción / Dokploy)
# =====================================================
# Copiar a .env.local y rellenar con valores reales.
# Variables NEXT_PUBLIC_* se inyectan EN TIEMPO DE BUILD.
# =====================================================

# ── General ──────────────────────────────────────────
NODE_ENV=production

# ── URLs públicas (inyectadas al build) ──────────────
# URL del frontend (canonical)
NEXT_PUBLIC_APP_URL=https://appacua.kronoxmx.com

# NEXT_PUBLIC_EXTERNAL_API_URL ya NO se usa para llamadas HTTP (el rewrite de Next.js
# las redirige automáticamente). Solo se usa como fallback para WebSockets si no se
# define NEXT_PUBLIC_WS_URL explícitamente. Puedes omitirla si defines WS_URL.
# NEXT_PUBLIC_EXTERNAL_API_URL=https://apiacua.kronoxmx.com

# WebSocket público del backend (conexión directa desde el navegador; SÍ es NEXT_PUBLIC)
NEXT_PUBLIC_WS_URL=wss://apiacua.kronoxmx.com/ws/lecturas

# ── URL privada del backend (server-side, lee el rewrite en runtime) ─────────
# Apunta al backend: puede ser la URL interna Docker o la URL pública.
# En producción Dokploy:  https://apiacua.kronoxmx.com
# En desarrollo local:    http://localhost:3100
EXTERNAL_API_URL=https://apiacua.kronoxmx.com

# ── Observabilidad (Opcional) ────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
